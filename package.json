{
  "name": "weather",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": ["packages/*"],
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "pnpm --filter @weather/protocol build && pnpm --filter @weather/client build && pnpm --filter @weather/server build",
    "start": "pnpm build && node packages/server/dist/index.js",
    "test": "pnpm --filter @weather/protocol test && pnpm --filter @weather/server test"
  }
}
